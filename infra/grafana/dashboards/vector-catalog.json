{
  "dashboard": {
    "title": "Vector Catalog Service",
    "timezone": "browser",
    "panels": [
      {
        "id": 1,
        "title": "Request Rate (QPS)",
        "type": "graph",
        "gridPos": {"x": 0, "y": 0, "w": 12, "h": 8},
        "targets": [
          {"expr": "rate(http_server_requests_seconds_count[5m])", "legendFormat": "RPS"}
        ]
      },
      {
        "id": 2,
        "title": "P99 Latency",
        "type": "graph",
        "gridPos": {"x": 12, "y": 0, "w": 12, "h": 8},
        "targets": [
          {"expr": "histogram_quantile(0.99, rate(http_server_requests_seconds_bucket[5m]))", "legendFormat": "P99"}
        ]
      },
      {
        "id": 3,
        "title": "Cache Hit Rate",
        "type": "gauge",
        "gridPos": {"x": 0, "y": 8, "w": 6, "h": 6},
        "targets": [
          {"expr": "rate(vectorcatalog_cache_hits_total[5m]) / (rate(vectorcatalog_cache_hits_total[5m]) + rate(vectorcatalog_cache_misses_total[5m]))"}
        ]
      },
      {
        "id": 4,
        "title": "Circuit Breaker State",
        "type": "stat",
        "gridPos": {"x": 6, "y": 8, "w": 6, "h": 6},
        "targets": [
          {"expr": "vectorcatalog_circuit_breaker_open"}
        ]
      }
    ]
  }
}
